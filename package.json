{
  "name": "sgi-market-caja",
  "version": "0.1.0",
  "private": true,
  "description": "SGI Market Caja local-first POS",
  "main": "electron/main.js",
  "scripts": {
    "start": "node app-local/server.js",
    "cloud": "node cloud/server.js",
    "desktop": "electron .",
    "dist": "electron-builder --win nsis",
    "check": "node --check app-local/server.js && node --check app-local/public/app.js && node --check electron/main.js && node --check cloud/server.js && node --check cloud/public/app.js"
  },
  "build": {
    "appId": "com.sgi.market.caja",
    "productName": "SGI Market Caja",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app-local/**/*",
      "electron/**/*",
      "package.json",
      "!app-local/data/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SGI Market Caja"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
